# Xcode and macOS generated files
# * Arquivos gerados pelo Xcode e macOS *
.DS_Store

# Xcode build directories
# * Pastas de build geradas pelo Xcode *
build/
DerivedData/

# Xcode local user settings
# * Configurações locais de usuário do Xcode *
*.xcworkspace/xcuserdata/
*.xcuserstate

# Custom internal metadata files
# * Arquivos internos personalizados *
*.xcus18
*.xcus21
*.xcus27
*.xcus28

# Swift Package Manager build artifacts
# * Artefatos de build do Swift Package Manager *
.build/

# CocoaPods user data
# * Dados de usuário do CocoaPods *
Pods/**/xcuserdata/
